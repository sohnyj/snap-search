{
  "manifest_version": 3,
  "name": "Snap Search",
  "version": "0.1",
  "description": "Select text to search with customizable search engines via a popup",
  "browser_specific_settings": {
    "gecko": {
      "id": "snap-search@sohnyj",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_title": "Snap Search Settings"
  },
  "background": {
    "scripts": ["lib/defaults.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/defaults.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
